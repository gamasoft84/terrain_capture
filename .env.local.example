NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Solo servidor (nunca NEXT_PUBLIC_). Scripts admin / sync (ej. npm run wipe:supabase).
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_HARDCODED_USER_ID=

# Mapbox GL (motor "Mapbox" en Ajustes)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Alias opcional compatible con algunos setups
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Maps JavaScript API (motor "Google" en Ajustes)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Opcional — teselas auxiliares si algún componente sigue usando MapTiler
NEXT_PUBLIC_MAPTILER_KEY=
